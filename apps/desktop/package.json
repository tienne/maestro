{
  "name": "@maestro/desktop",
  "version": "0.1.0",
  "description": "Maestro - AI Agent Orchestration Desktop App",
  "private": true,
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build && electron-builder",
