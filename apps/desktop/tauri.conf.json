{
  "$schema": "../../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "maestro",
  "version": "0.1.0",
  "identifier": "dev.maestro.app",
  "build": {
    "frontendDist": "../web/out",
    "devUrl": "http://localhost:3000",
    "beforeDevCommand": "npm run dev -w apps/web",
    "beforeBuildCommand": "npm run build -w apps/web && npm run export -w apps/web"
  },
  "app": {
    "windows": [
      {
        "title": "Maestro",
        "width": 1440,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
