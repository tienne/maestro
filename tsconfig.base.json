{
  "compileOnSave": false,
  "compilerOptions": {
    "rootDir": ".",
    "sourceMap": true,
    "declaration": false,
    "moduleResolution": "bundler",
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "importHelpers": true,
    "target": "ES2022",
    "module": "ESNext",
    "lib": ["ES2022", "dom"],
    "skipLibCheck": true,
    "strict": true,
    "skipDefaultLibCheck": true,
    "baseUrl": ".",
    "paths": {
      "@maestro/shared-types": ["packages/shared-types/src/index.ts"],
      "@maestro/cli": ["packages/cli/src/index.ts"],
      "@maestro/tokens": ["packages/tokens/src/index.ts"]
    }
  }
}
